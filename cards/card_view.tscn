[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://cards/card_view.gd" id="1"]

[node name="CardView" type="PanelContainer"]
custom_minimum_size = Vector2(180, 250)
mouse_default_cursor_shape = 2
script = ExtResource("1")

[node name="Margin" type="MarginContainer" parent="."]
theme_override_constants/margin_left = 12
theme_override_constants/margin_top = 12
theme_override_constants/margin_right = 12
theme_override_constants/margin_bottom = 12

[node name="Content" type="VBoxContainer" parent="Margin"]

[node name="Header" type="HBoxContainer" parent="Margin/Content"]

[node name="NameLabel" type="Label" parent="Margin/Content/Header"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
text = "Card Name"

[node name="CostLabel" type="Label" parent="Margin/Content/Header"]
unique_name_in_owner = true
layout_mode = 2
text = "1"

[node name="ArtworkPlaceholder" type="ColorRect" parent="Margin/Content"]
custom_minimum_size = Vector2(0, 100)
layout_mode = 2
color = Color(0.18, 0.22, 0.3, 1)

[node name="DescriptionLabel" type="Label" parent="Margin/Content"]
unique_name_in_owner = true
layout_mode = 2
size_flags_vertical = 3
text = "Card description"
autowrap_mode = 2

[node name="SelectButton" type="Button" parent="."]
unique_name_in_owner = true
layout_mode = 2
mouse_default_cursor_shape = 2
focus_mode = 0
flat = true

[connection signal="pressed" from="SelectButton" to="." method="_on_select_button_pressed"]
[connection signal="mouse_entered" from="SelectButton" to="." method="_on_select_button_mouse_entered"]
[connection signal="mouse_exited" from="SelectButton" to="." method="_on_select_button_mouse_exited"]
