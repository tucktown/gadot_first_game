[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://screens/run_complete.gd" id="1"]

[node name="RunComplete" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.055, 0.071, 0.11, 1)
mouse_filter = 2

[node name="Center" type="CenterContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="Content" type="VBoxContainer" parent="Center"]
custom_minimum_size = Vector2(620, 0)
layout_mode = 2
theme_override_constants/separation = 24
alignment = 1

[node name="Title" type="Label" parent="Center/Content"]
layout_mode = 2
theme_override_colors/font_color = Color(0.95, 0.78, 0.3, 1)
theme_override_font_sizes/font_size = 52
text = "RUN COMPLETE"
horizontal_alignment = 1

[node name="SummaryLabel" type="Label" parent="Center/Content"]
unique_name_in_owner = true
layout_mode = 2
text = "You defeated all three encounters."
horizontal_alignment = 1
autowrap_mode = 2

[node name="NewRunButton" type="Button" parent="Center/Content"]
custom_minimum_size = Vector2(260, 52)
layout_mode = 2
mouse_default_cursor_shape = 2
text = "Start Another Run"

[node name="TitleButton" type="Button" parent="Center/Content"]
custom_minimum_size = Vector2(260, 52)
layout_mode = 2
mouse_default_cursor_shape = 2
text = "Return to Title"

[connection signal="pressed" from="Center/Content/NewRunButton" to="." method="_on_new_run_button_pressed"]
[connection signal="pressed" from="Center/Content/TitleButton" to="." method="_on_title_button_pressed"]
